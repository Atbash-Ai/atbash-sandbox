{
  "name": "Atbash Sandbox",

  // Use Codespaces' official Node.js base image instead of building our root
  // Dockerfile here. Two reasons:
  //   1. Codespaces post-creation injects its `vscode` user + VS Code Server
  //      into whichever image you start with. Our hardened Dockerfile only
  //      defines an `atbash` user (uid 10001), so that injection fails and
  //      Codespaces silently falls back to a recovery container — defeating
  //      the point of shipping a devcontainer.
  //   2. Codespaces is for dev-loop convenience, not the security target.
  //      The hardened Dockerfile + Compose / Fly / Cloud Run manifests stay
  //      the source of truth for the production-style sandbox.
  //
  // We install @atbash/cli via postCreateCommand below — same pinned version
  // as the Dockerfile.
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22-bookworm",

  "containerEnv": {
    "ATBASH_AGENT_KEY": "${localEnv:ATBASH_AGENT_KEY}",
    "ATBASH_ORG_NAME":  "${localEnv:ATBASH_ORG_NAME}"
  },
  "remoteEnv": {
    "ATBASH_AGENT_KEY": "${localEnv:ATBASH_AGENT_KEY}",
    "ATBASH_ORG_NAME":  "${localEnv:ATBASH_ORG_NAME}"
  },

  // Install the CLI, seed the telemetry opt-out file, and verify the version
  // matches the pin. Runs once after the container is created.
  "postCreateCommand": "sudo npm install -g @atbash/cli@0.3.18 && mkdir -p $HOME/.config/atbash && cp ${containerWorkspaceFolder}/telemetry/telemetry.json $HOME/.config/atbash/telemetry.json && chmod 0700 $HOME/.config/atbash && chmod 0600 $HOME/.config/atbash/telemetry.json && atbash --version",

  "postAttachCommand": "echo 'Atbash sandbox ready. Detailed tests at tests/run-all.sh, smoke test at ./test-suite.sh. Set ATBASH_AGENT_KEY and ATBASH_ORG_NAME before running.'"
}
