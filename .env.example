# Copy this file to `.env` if you want to pre-set values for `docker compose run`.
# `.env` is gitignored — keep it out of version control.
#
# All values are OPTIONAL: the sandbox entrypoint will generate an agent key
# on first run and print the public key for you to onboard at https://atbash.ai/.

# Optional — pre-set agent private key (skip the on-first-run keygen).
# ATBASH_AGENT_KEY=your-64-hex-private-key

# Optional — your org's name on atbash.ai.
# ATBASH_ORG_NAME=your-org

# Optional — custom judge endpoint (default: https://atbash.ai).
# ATBASH_ENDPOINT=

# Optional overrides.
# ATBASH_BLOCKCHAIN_RID=
# ATBASH_PROVIDER=
# ATBASH_PROVIDER_MODEL=
